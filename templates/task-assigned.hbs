<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Task Assigned</title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f5f5f5; margin: 0; padding: 20px; }
    .container { max-width: 600px; margin: 0 auto; background: #fff; border-radius: 8px; overflow: hidden; }
    .header { background: #f59e0b; padding: 28px 40px; }
    .header h1 { color: #fff; margin: 0; font-size: 20px; font-weight: 700; }
    .body { padding: 40px; }
    .task-box { background: #fffbeb; border-left: 4px solid #f59e0b; padding: 16px 20px; border-radius: 4px; margin: 20px 0; }
    .task-box h2 { margin: 0 0 8px; color: #1a1a1a; font-size: 18px; }
    .task-box p { margin: 4px 0; color: #555; font-size: 14px; }
    .footer { padding: 24px 40px; border-top: 1px solid #eee; text-align: center; }
    .footer p { color: #999; font-size: 12px; margin: 0; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>📋 New Task Assigned</h1>
    </div>
    <div class="body">
      <p>Hi <strong>{{name}}</strong>, a new task has been assigned to you.</p>
      <div class="task-box">
        <h2>{{taskTitle}}</h2>
        {{#if eventTitle}}<p><strong>Event:</strong> {{eventTitle}}</p>{{/if}}
        {{#if dueDate}}<p><strong>Due:</strong> {{dueDate}}</p>{{/if}}
      </div>
      <p>Log in to Assembl to view details and get started.</p>
    </div>
    <div class="footer">
      <p>&copy; {{year}} Assembl. All rights reserved.</p>
    </div>
  </div>
</body>
</html>
