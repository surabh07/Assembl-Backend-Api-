<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Task Overdue</title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f5f5f5; margin: 0; padding: 20px; }
    .container { max-width: 600px; margin: 0 auto; background: #fff; border-radius: 8px; overflow: hidden; }
    .header { background: #ef4444; padding: 28px 40px; }
    .header h1 { color: #fff; margin: 0; font-size: 20px; font-weight: 700; }
    .body { padding: 40px; color: #4a4a4a; line-height: 1.6; }
    .alert-box { background: #fef2f2; border-left: 4px solid #ef4444; padding: 16px 20px; border-radius: 4px; margin: 20px 0; }
    .footer { padding: 24px 40px; border-top: 1px solid #eee; text-align: center; }
    .footer p { color: #999; font-size: 12px; margin: 0; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>⏰ Task Overdue</h1>
    </div>
    <div class="body">
      <p>Hi <strong>{{name}}</strong>,</p>
      <div class="alert-box">
        <p><strong>{{taskTitle}}</strong> was due on <strong>{{dueDate}}</strong> and is now overdue.</p>
        {{#if eventTitle}}<p>Event: {{eventTitle}}</p>{{/if}}
      </div>
      <p>Please update the task status or complete it as soon as possible.</p>
    </div>
    <div class="footer">
      <p>&copy; {{year}} Assembl. All rights reserved.</p>
    </div>
  </div>
</body>
</html>
