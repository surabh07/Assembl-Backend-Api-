<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Daily Briefing</title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f5f5f5; margin: 0; padding: 20px; }
    .container { max-width: 600px; margin: 0 auto; background: #fff; border-radius: 8px; overflow: hidden; }
    .header { background: #6366f1; padding: 28px 40px; }
    .header h1 { color: #fff; margin: 0; font-size: 20px; font-weight: 700; }
    .header p { color: #c7d2fe; margin: 4px 0 0; font-size: 14px; }
    .body { padding: 40px; color: #4a4a4a; }
    .slot { display: flex; padding: 12px 0; border-bottom: 1px solid #f0f0f0; }
    .slot-time { width: 80px; font-weight: 600; color: #6366f1; flex-shrink: 0; font-size: 13px; }
    .slot-info h4 { margin: 0 0 4px; color: #1a1a1a; font-size: 15px; }
    .slot-info p { margin: 0; color: #888; font-size: 13px; }
    .footer { padding: 24px 40px; border-top: 1px solid #eee; text-align: center; }
    .footer p { color: #999; font-size: 12px; margin: 0; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>📋 Today's Briefing</h1>
      <p>{{eventTitle}} — {{date}}</p>
    </div>
    <div class="body">
      <p>Hi <strong>{{name}}</strong>, here's your schedule for today:</p>
      {{#each slots}}
      <div class="slot">
        <div class="slot-time">{{startTime}}</div>
        <div class="slot-info">
          <h4>{{title}}</h4>
          {{#if location}}<p>📍 {{location}}</p>{{/if}}
        </div>
      </div>
      {{/each}}
    </div>
    <div class="footer">
      <p>&copy; {{year}} Assembl. All rights reserved.</p>
    </div>
  </div>
</body>
</html>
