<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Registration Confirmed</title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f5f5f5; margin: 0; padding: 20px; }
    .container { max-width: 600px; margin: 0 auto; background: #fff; border-radius: 8px; overflow: hidden; }
    .header { background: #6366f1; padding: 32px 40px; text-align: center; }
    .header h1 { color: #fff; margin: 0; font-size: 24px; font-weight: 700; }
    .body { padding: 40px; }
    .code-box { background: #f0f0ff; border: 2px dashed #6366f1; border-radius: 8px; padding: 20px; text-align: center; margin: 24px 0; }
    .code-box p { margin: 0 0 8px; color: #555; font-size: 14px; }
    .code-box span { font-size: 32px; font-weight: 800; letter-spacing: 4px; color: #6366f1; font-family: monospace; }
    .detail { display: flex; margin-bottom: 12px; }
    .detail strong { width: 120px; color: #333; flex-shrink: 0; }
    .detail span { color: #555; }
    .footer { padding: 24px 40px; border-top: 1px solid #eee; text-align: center; }
    .footer p { color: #999; font-size: 12px; margin: 0; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>You're registered! 🎉</h1>
    </div>
    <div class="body">
      <p>Hi <strong>{{name}}</strong>,</p>
      <p>Your registration for <strong>{{eventTitle}}</strong> is confirmed. See you there!</p>
      <div class="code-box">
        <p>Your Check-in Code</p>
        <span>{{checkInCode}}</span>
      </div>
      <div class="detail"><strong>Date:</strong><span>{{startDate}}</span></div>
      {{#if isVirtual}}
      <div class="detail"><strong>Format:</strong><span>Virtual Event</span></div>
      {{else}}
      <div class="detail"><strong>Location:</strong><span>{{location}}</span></div>
      {{/if}}
      <p style="color: #888; font-size: 13px;">A calendar invite is attached to this email.</p>
    </div>
    <div class="footer">
      <p>&copy; {{year}} Assembl. All rights reserved.</p>
    </div>
  </div>
</body>
</html>
