<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Event Reminder</title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f5f5f5; margin: 0; padding: 20px; }
    .container { max-width: 600px; margin: 0 auto; background: #fff; border-radius: 8px; overflow: hidden; }
    .header { background: #f59e0b; padding: 28px 40px; }
    .header h1 { color: #fff; margin: 0; font-size: 20px; font-weight: 700; }
    .body { padding: 40px; color: #4a4a4a; line-height: 1.6; }
    .event-card { background: #fffbeb; border: 1px solid #fde68a; border-radius: 8px; padding: 20px; margin: 20px 0; }
    .event-card h2 { color: #1a1a1a; margin: 0 0 12px; font-size: 20px; }
    .detail { margin-bottom: 8px; color: #555; }
    .code-box { background: #f0f0ff; border: 2px dashed #6366f1; border-radius: 8px; padding: 16px; text-align: center; margin: 16px 0; }
    .code-box p { margin: 0 0 4px; color: #555; font-size: 13px; }
    .code-box span { font-size: 28px; font-weight: 800; letter-spacing: 4px; color: #6366f1; font-family: monospace; }
    .footer { padding: 24px 40px; border-top: 1px solid #eee; text-align: center; }
    .footer p { color: #999; font-size: 12px; margin: 0; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>⏰ Your event is tomorrow!</h1>
    </div>
    <div class="body">
      <p>Hi <strong>{{name}}</strong>,</p>
      <p>Don't forget — you're registered for an event tomorrow!</p>
      <div class="event-card">
        <h2>{{eventTitle}}</h2>
        <div class="detail">📅 {{startDate}}</div>
        {{#if isVirtual}}
        <div class="detail">💻 Virtual Event</div>
        {{else}}
        <div class="detail">📍 {{location}}</div>
        {{/if}}
      </div>
      <div class="code-box">
        <p>Your Check-in Code</p>
        <span>{{checkInCode}}</span>
      </div>
      <p>Show this code at the registration desk for a quick check-in.</p>
    </div>
    <div class="footer">
      <p>&copy; {{year}} Assembl. All rights reserved.</p>
    </div>
  </div>
</body>
</html>
