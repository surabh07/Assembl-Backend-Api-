<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Meeting Notes</title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f5f5f5; margin: 0; padding: 20px; }
    .container { max-width: 600px; margin: 0 auto; background: #fff; border-radius: 8px; overflow: hidden; }
    .header { background: #0ea5e9; padding: 28px 40px; }
    .header h1 { color: #fff; margin: 0; font-size: 20px; font-weight: 700; }
    .body { padding: 40px; color: #4a4a4a; line-height: 1.6; }
    .section { margin-bottom: 24px; }
    .section h3 { color: #1a1a1a; margin-bottom: 8px; }
    .action-item { padding: 6px 0; border-bottom: 1px solid #f0f0f0; }
    .btn { display: inline-block; background: #0ea5e9; color: #fff; text-decoration: none; padding: 10px 24px; border-radius: 6px; font-weight: 600; }
    .footer { padding: 24px 40px; border-top: 1px solid #eee; text-align: center; }
    .footer p { color: #999; font-size: 12px; margin: 0; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>📝 Meeting Notes: {{noteTitle}}</h1>
    </div>
    <div class="body">
      <p>Hi <strong>{{name}}</strong>,</p>
      <div class="section">
        <h3>Summary</h3>
        <p>{{content}}</p>
      </div>
      {{#if actionItems.length}}
      <div class="section">
        <h3>Action Items</h3>
        {{#each actionItems}}
        <div class="action-item">• {{this}}</div>
        {{/each}}
      </div>
      {{/if}}
      <a href="{{noteUrl}}" class="btn">View Full Notes</a>
    </div>
    <div class="footer">
      <p>&copy; {{year}} Assembl. All rights reserved.</p>
    </div>
  </div>
</body>
</html>
