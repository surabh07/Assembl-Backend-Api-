# ============================================================
# Assembl API — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# App
NODE_ENV=development
PORT=3000

# Database — NeonDB pooled connection string
# Format: postgresql://user:pass@host/db?pgbouncer=true&connect_timeout=15
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/assembl?pgbouncer=true&connect_timeout=15

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# SMTP (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-smtp-password
SMTP_FROM="Assembl <no-reply@assembl.app>"

# Frontend URL (for email links, CORS)
FRONTEND_URL=http://localhost:5173

# ============================================================
# OPTIONAL INTEGRATIONS
# Leave blank to disable — all channels fail silently
# ============================================================

# WhatsApp (Twilio) — per-user opt-in notifications
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Microsoft Teams — org-level channel webhook
# TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...

# Slack — org-level channel webhook
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Discord — org-level webhook
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Google Calendar OAuth — shared ops calendar sync + .ics generation
# GOOGLE_CALENDAR_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CALENDAR_CLIENT_SECRET=your-client-secret
# GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/api/v1/auth/google/callback
# GOOGLE_CALENDAR_ID=primary
